<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- UDP send/receive to base-radio -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to query the current Wi-Fi network state before resolving
         lidarbase.local / sending control commands, and to acquire the
         multicast lock used by MdnsResolver. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required for MdnsResolver's MulticastSocket -- Android drops
         incoming multicast packets by default to save radio power unless
         the app explicitly holds this permission + a WifiManager.MulticastLock
         (see MdnsResolver.resolveWithLock). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LidarBotSystem"
        android:usesCleartextTraffic="true">
        <!-- usesCleartextTraffic: this app only ever talks plaintext UDP to
             base-radio on the local network (no HTTP/HTTPS traffic at all);
             cleartext-traffic blocking (default since API 28) targets HTTP,
             but is declared permissively here since this app has no TLS
             story by design -- see README "Known limitations". -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LidarBotSystem">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
