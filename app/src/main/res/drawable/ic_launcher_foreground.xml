<?xml version="1.0" encoding="utf-8"?>
<!-- Minimal vector mark: a sweeping radar arc + range rings, evoking the
     polar lidar-scan rendering in ui/LidarScreen.kt's Canvas. Drawn purely
     in XML vector paths rather than a placeholder/PNG so the app builds
     and installs with a real (if simple) icon, with no binary asset
     dependency. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,54 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,54 L54,18 A36,36 0 0,1 84.36,72"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:fillColor="#33FFFFFF" />
    <path
        android:pathData="M54,54 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#FFFFFF" />
</vector>
